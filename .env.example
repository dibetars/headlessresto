# ============================================================
# RestaurantOS — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PowerSync
NEXT_PUBLIC_POWERSYNC_URL=https://your-instance.powersync.com
POWERSYNC_PRIVATE_KEY=...

# Stripe (your platform account — restaurants connect theirs via OAuth)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Redis (BullMQ + caching)
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_URL=http://localhost:3001

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPER_ADMIN_EMAILS=you@yourcompany.com

# Resend (transactional email)
RESEND_API_KEY=re_...

# Sentry (error tracking)
SENTRY_DSN=https://...
